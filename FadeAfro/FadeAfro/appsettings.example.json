{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "YOUR_POSTGRES_CONNECTION_STRING"
  },
  "Telegram": {
    "BotToken": "YOUR_BOT_TOKEN",
    "SkipValidation": false
  },
  "Jwt": {
    "SecretKey": "YOUR_SECRET_KEY_MIN_32_CHARS_LONG",
    "Issuer": "FadeAfro",
    "Audience": "FadeAfroApp",
    "ExpirationMinutes": "60"
  },
  "Cors": {
    "AllowedOrigins": [ "https://YOUR_FRONTEND_DOMAIN" ]
  },
  "Time": {
    "TimeZone": "Europe/Moscow"
  }
}
